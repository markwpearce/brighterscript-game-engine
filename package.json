{
    "name": "brighterscript-game-engine",
    "version": "0.5.0",
    "description": "Game Engine for Roku written in Brighterscript.",
    "author": "Mark Pearce",
    "keywords": [
        "ropm",
        "roku",
        "brighterscript",
        "brightscript",
        "game engine"
    ],
    "scripts": {
        "build": "npm run clean && bsc --project bsconfig.build.json --create-package=false",
        "preversion": "npm run validate",
        "validate": "bsc --project bsconfig.build.json --create-package=false --copy-to-staging=false && bsc --project bsconfig.test.json --create-package=false --copy-to-staging=false",
        "clean": "rimraf brighterscript*.tgz  && rimraf out && rimraf build && rimraf test-build",
        "clean-all": "npm run clean && node scripts/examples.js clean",
        "docs": "rimraf docs && ./node_modules/.bin/jsdoc -c jsdoc.json -d docs",
        "docs-server": "npm run docs && npx http-server docs",
        "prepare-examples": "npm run build && node scripts/examples.js install",
        "validate-examples": "npm run validate && node scripts/examples.js validate",
        "build-examples": "npm run build && node scripts/examples.js build",
        "create-example": "node scripts/create-example.js",
        "lint": "bslint",
        "build-tests": "bsc --project bsconfig.test.json --create-package=false",
        "test:device": "npx rooibos --project=bsconfig.test.json --host=$ROKU_HOST --password=$ROKU_PASSWORD",
        "test:ci": "npm run build-tests && node scripts/run-tests-ci.js"
    },
    "files": [
        "src/**/*",
        "!src/source/roku_modules/**",
        "!src/**/*.spec.bs"
    ],
    "license": "MIT",
    "devDependencies": {
        "@rokucommunity/bslint": "^1.0.0-alpha.50",
        "brighterscript": "^1.0.0-alpha.50",
        "brighterscript-jsdocs-plugin": "^0.8.1",
        "brs-node": "^2.2.0",
        "clean-jsdoc-theme": "^5.0.8",
        "pureimage": "^0.4.20",
        "rimraf": "^6.1.3",
        "roku-deploy": "4.0.0-alpha.2",
        "rokubot": "^0.3.0",
        "rooibos-roku": "6.0.0-alpha.52",
        "ropm": "^0.11.9"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/markwpearce/brighterscript-game-engine.git"
    },
    "homepage": "https://github.com/markwpearce/brighterscript-game-engine#readme",
    "bugs": {
        "url": "https://github.com/markwpearce/brighterscript-game-engine/issues"
    },
    "ropm": {
        "rootDir": "src",
        "packageRootDir": "src"
    },
    "overrides": {},
    "dependencies": {
        "rodash": "npm:@tkss/rodash@^0.0.20"
    }
}
