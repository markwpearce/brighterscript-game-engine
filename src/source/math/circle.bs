namespace BGE.Math

  class Circle
    x as float
    y as float
    radius as float = 0

    sub new(x = 0 as float, y = 0 as float, radius = 0 as float)
      m.x = x
      m.y = y
      m.radius = radius
    end sub

    override function copy() as Circle
      return new Circle(m.x, m.y, m.radius)
    end function

  end class
end namespace
