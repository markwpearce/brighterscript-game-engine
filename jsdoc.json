{
    "plugins": [
        "plugins/markdown",
        "./node_modules/brighterscript-jsdocs-plugin/convert-brighterscript-docs.js"
    ],
    "source": {
        "include": ["src", "README.md"],
        "exclude": ["src/roku_modules"],
        "includePattern": ".+\\.br?s$",
        "excludePattern": "roku_modules"
    },
    "templates": {
        "referenceTitle": "Brighterscript Game Engine",
        "collapse": true
    },
    "opts": {
        "recurse": true,
        "template": "./node_modules/clean-jsdoc-theme",
        "brighterscript-jsdocs-plugin": {
            "addModule": false
        },
        "theme_opts": {
            "homepageTitle": "Brighterscript Game Engine",
            "menu": [
                {
                    "title": "HOME",
                    "link": "../docs/index.html",
                    "id": "home"
                }
            ],
            "sections": ["Namespaces", "Classes", "Interfaces"]
        }
    }
}
