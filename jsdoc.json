{
    "plugins": [
        "plugins/markdown",
        "./node_modules/brighterscript-jsdocs-plugin/convert-brighterscript-docs.js"
    ],
    "source": {
        "include": ["src", "README.md"],
        "exclude": ["src/roku_modules"],
        "includePattern": ".+\\.br?s$",
        "excludePattern": "roku_modules"
    },
    "templates": {
        "referenceTitle": "Brighterscript Game Engine",
        "collapse": true
    },
    "opts": {
        "recurse": true,
        "template": "./node_modules/clean-jsdoc-theme/dist",
        "brighterscript-jsdocs-plugin": {
            "addModule": false
        },
        "siteName": "Brighterscript Game Engine",
        "menu": [
            {
                "id": "home"
            }
        ],
        "sectionOrder": ["Namespaces", "Classes", "Interfaces"]
    }
}
