{
    "plugins": [
        "plugins/markdown",
        "./node_modules/brighterscript-jsdocs-plugin/convert-brighterscript-docs.js"
    ],
    "source": {
        "include": ["src", "README.md"],
        "exclude": ["src/roku_modules"],
        "includePattern": ".+\\.br?s$",
        "excludePattern": "(roku_modules|\\.spec\\.bs$)"
    },
    "templates": {
        "referenceTitle": "Brighterscript Game Engine",
        "collapse": true
    },
    "opts": {
        "recurse": true,
        "template": "./node_modules/clean-jsdoc-theme/dist",
        "brighterscript-jsdocs-plugin": {
            "addModule": false
        },
        "siteName": "Brighterscript Game Engine",
        "menu": [
            {
                "id": "home"
            },
            {
                "title": "GitHub",
                "link": "https://github.com/markwpearce/brighterscript-game-engine",
                "icon": "simpleicons:github",
                "target": "_blank"
            }
        ],
        "sectionOrder": ["Namespaces", "Classes", "Interfaces"],
        "fonts": {
            "heading": "Sora",
            "body": "Inter",
            "mono": "JetBrains Mono"
        },
        "colors": {
            "bg": "oklch(1 0 0)",
            "bgMuted": "oklch(0.97 0 0)",
            "fg": "oklch(0.15 0 0)",
            "fgMuted": "oklch(0.45 0 0)",
            "accent": "oklch(0.55 0.18 265)",
            "accentFg": "oklch(0.98 0 0)",
            "border": "oklch(0.9 0 0)"
        },
        "darkColors": {
            "bg": "oklch(0.16 0.005 265)",
            "bgMuted": "oklch(0.22 0.005 265)",
            "fg": "oklch(0.95 0 0)",
            "fgMuted": "oklch(0.65 0.01 265)",
            "accent": "oklch(0.72 0.16 265)",
            "accentFg": "oklch(0.15 0 0)",
            "border": "oklch(0.3 0.01 265)"
        }
    }
}
