
sub updateDrawMode(entity as BGE.GameEntity)
  for each drawable in entity.drawables
    drawable.drawMode = (drawable.drawMode + 1)
    if drawable.drawMode > BGE.MAX_DRAW_MODE
      drawable.drawMode = 0 as BGE.SceneObjectDrawMode
    end if
  end for
  print "Draw Mode is now: " + entity.drawables[0].drawMode.toStr() + " for entity: " + entity.name
end sub
