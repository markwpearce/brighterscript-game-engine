{
    "extends": "../../bsconfig.build.json",
    "rootDir": "src",
    "outDir": "build",
    "files": [
        "**/*",
        {
            "src": "../../../src/**/*",
            "dest": "source/roku_modules"
        },
        "!../../../src/**/*.spec.bs"
    ],
    "emitDefinitions": false,
    "diagnosticFilters": [
        {
            "files": "../../../src/source/roku_modules/**/*"
        }
    ]
}
