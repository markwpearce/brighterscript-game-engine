sub main()
  screenWidth = 1280
  screenHeight = 720

  screen = CreateObject("roScreen", true, screenWidth, screenHeight)
  renderObj = new BGE.Renderer(screen)

  renderObj.drawPolygon([
    {x: 100, y: 100},
    {x: 200, y: 100},
    {x: 200, y: 200},
  ], 200, 200, BGE.Colors().Red)
  screen.SwapBuffers()

  sleep(1000)
end sub
