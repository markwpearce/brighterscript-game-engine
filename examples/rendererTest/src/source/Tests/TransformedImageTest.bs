' Demonstrates Renderer.drawTransformedObject() (rotation + non-uniform x/y
' scale) by cycling through 4 phases, one step per second: increasing x
' scale, increasing y scale, increasing rotation at equal scale, and
' increasing rotation at unequal scale.
class TransformedImageTest extends RendererTest

  image as roBitmap
  phase as integer = 0
  step as integer = 0
  elapsedSeconds as float = 0
  label as string = ""

  sub new()
    super("Transform: Rotate & Scale an Image")
  end sub

  override sub setup(renderer as BGE.Renderer)
    m.image = CreateObject("roBitmap", "pkg:/images/rokuHomescreen.jpg")
  end sub

  override sub update(dt as float)
    m.elapsedSeconds += dt
    if m.elapsedSeconds >= 1
      m.elapsedSeconds = 0
      m.step++
      if m.step > 10
        m.step = 0
        m.phase = (m.phase + 1) mod 4
      end if
    end if
  end sub

  override sub draw(renderer as BGE.Renderer)
    degrees = 45
    scaleX = 0.5
    scaleY = 0.5

    if m.phase = 0
      scaleX = 0.1 * m.step
      m.label = "45 deg rotation, increasing x scale - x/y = " + (scaleX / scaleY).toStr()
    else if m.phase = 1
      scaleY = 0.1 * (m.step + 1)
      m.label = "45 deg rotation, increasing y scale - x/y = " + (scaleX / scaleY).toStr()
    else if m.phase = 2
      degrees = m.step * 5
      m.label = "Increasing rotation, equal scale (x/y = 1), deg = " + degrees.toStr()
    else
      scaleX = 0.2
      degrees = m.step * 5
      m.label = "Increasing rotation, unequal scale - x/y = " + (scaleX / scaleY).toStr() + ", deg = " + degrees.toStr()
    end if

    renderer.drawTransformedObject(200, 200, scaleX, scaleY, BGE.Math.DegreesToRadians(degrees), m.image)
    renderer.drawText(m.label, 200, 620, BGE.Colors.White, invalid)
  end sub

end class
