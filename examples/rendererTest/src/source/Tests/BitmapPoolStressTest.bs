' Stress-tests allocating many small bitmaps in a tight loop (demonstrating
' what happens as available bitmap memory gets exhausted, and how quickly
' the runtime can recover via RunGarbageCollector()). Triggered by OK rather
' than running every frame, since it's CPU/memory heavy - shows elapsed time
' and how many bitmaps were actually created afterward.
class BitmapPoolStressTest extends RendererTest

  resultText as string = "Press OK to run the stress test"

  sub new()
    super("Bitmap Pool: Allocation Stress Test")
  end sub

  override sub onInput(buttonName as string)
    if buttonName = "OK"
      m.runStressTest()
    end if
  end sub

  sub runStressTest()
    size = 400
    count = 100
    created = 0
    timer = CreateObject("roTimespan")

    for i = 0 to count - 1
      bmp = CreateObject("roBitmap", {width: size, height: size, alphaEnable: true})
      if invalid = bmp
        RunGarbageCollector()
      else
        created++
      end if
    end for

    m.resultText = `Created ${created}/${count} ${size}x${size} bitmaps in ${timer.TotalMilliseconds()}ms - press OK to run again`
  end sub

  override sub draw(renderer as BGE.Renderer)
    canvasCenter = renderer.getCanvasCenter()
    renderer.drawText(m.resultText, canvasCenter.x, canvasCenter.y, BGE.Colors.White, invalid, "center")
  end sub

end class
