' Demonstrates Renderer.drawTriangle() (a fixed triangle, and a randomized
' one that reshuffles every couple seconds or on OK) alongside
' drawTransformedObject() drawing the renderer's own cached right-triangle
' resource (Renderer.resources.rightTriangle).
class TriangleDrawingTest extends RendererTest

  elapsedSeconds as float = 0
  randomTrianglePoints as object

  sub new()
    super("Drawing: Triangles")
  end sub

  override sub setup(renderer as BGE.Renderer)
    m.randomizeTriangle()
  end sub

  sub randomizeTriangle()
    targetSize = 200
    m.randomTrianglePoints = [
      {x: rnd(targetSize * 2), y: rnd(targetSize * 2)},
      {x: rnd(targetSize * 2), y: rnd(targetSize * 2)},
      {x: rnd(targetSize * 2), y: rnd(targetSize * 2)}
    ]
  end sub

  override sub update(dt as float)
    m.elapsedSeconds += dt
    if m.elapsedSeconds >= 2
      m.elapsedSeconds = 0
      m.randomizeTriangle()
    end if
  end sub

  override sub onInput(buttonName as string)
    if buttonName = "OK"
      m.elapsedSeconds = 0
      m.randomizeTriangle()
    end if
  end sub

  override sub draw(renderer as BGE.Renderer)
    targetSize = 200
    offset = 150

    ' A fixed right-triangle, drawn point-by-point
    renderer.drawTriangle([
      {x: 0, y: 0},
      {x: targetSize, y: 0},
      {x: targetSize, y: targetSize}
    ], offset, offset, BGE.Colors.Red)

    ' The renderer's own cached right-triangle resource, drawn via
    ' drawTransformedObject instead of drawTriangle
    triangleResourceScale = targetSize / BGE.RendererResourceSize
    renderer.drawTransformedObject(targetSize + 2 * offset, offset, triangleResourceScale, triangleResourceScale, 0, renderer.resources.rightTriangle.bitmap)

    ' A random triangle that reshuffles every couple of seconds (or on OK)
    renderer.drawTriangle(m.randomTrianglePoints, offset * 3 + targetSize * 2, offset, BGE.Colors.Green)
  end sub

end class
