' Demonstrates Renderer.drawBitmapTriangle() - warping a bitmap onto an
' arbitrary destination *triangle* (as opposed to drawTriangle's flat solid
' color, or drawPinnedCorners' 4-point quad warp). Draws the same source
' triangle warped onto two different destination triangles, animating one
' of them so it's obvious this keeps redrawing every frame.
class BitmapTriangleWarpTest extends RendererTest

  logoRegionWithId as object
  elapsedSeconds as float = 0

  sub new()
    super("Drawing: Bitmap Triangle Warp")
  end sub

  override sub setup(renderer as BGE.Renderer)
    bitmap = CreateObject("roBitmap", "pkg:/sprites/roku-logo-purple.png")
    region = CreateObject("roRegion", bitmap, 0, 0, bitmap.GetWidth(), bitmap.GetHeight())
    m.logoRegionWithId = BGE.RendererHelpers.createRegionWithId(region, "logo")
  end sub

  override sub update(dt as float)
    m.elapsedSeconds += dt
  end sub

  override sub draw(renderer as BGE.Renderer)
    srcPoints = [
      BGE.Math.VectorOps.create(0, 0),
      BGE.Math.VectorOps.create(0, 400),
      BGE.Math.VectorOps.create(400, 400)
    ]

    ' A fixed destination triangle
    destPoints = [
      BGE.Math.VectorOps.create(200, 200),
      BGE.Math.VectorOps.create(400, 250),
      BGE.Math.VectorOps.create(410, 150)
    ]
    renderer.drawBitmapTriangle(m.logoRegionWithId, srcPoints, destPoints)

    ' A destination triangle whose third point orbits, so the warp
    ' visibly changes shape every frame
    angle = m.elapsedSeconds
    orbitPoint = BGE.Math.VectorOps.create(900 + cos(angle) * 60, 500 + sin(angle) * 60)
    animatedDestPoints = [
      BGE.Math.VectorOps.create(800, 500),
      BGE.Math.VectorOps.create(1000, 550),
      orbitPoint
    ]
    renderer.drawBitmapTriangle(m.logoRegionWithId, srcPoints, animatedDestPoints)

    ' drawBitmapTriangle stages its scratch bitmaps for return rather than
    ' returning them immediately (so several calls this frame can share a
    ' surface) - without this, the pool exhausts within a couple of frames
    ' of continuous redrawing
    renderer.bmpPool.returnStagedRegions()
  end sub

end class
