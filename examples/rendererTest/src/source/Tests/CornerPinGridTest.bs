' Demonstrates Renderer.drawPinnedCorners() - drawing an image warped to an
' arbitrary quadrilateral (its 4 corner points), tiled in a grid. Rendered
' once into a cached bitmap in setup() rather than redone every frame -
' drawPinnedCorners is relatively expensive, and this is a static layout.
class CornerPinGridTest extends RendererTest

  gridBitmap as roBitmap

  sub new()
    super("Corner Pin: Grid of Pinned Corners")
  end sub

  override sub setup(renderer as BGE.Renderer)
    bitmap = CreateObject("roBitmap", "pkg:/sprites/roku-logo-purple.png")
    bitmap.SetAlphaEnable(true)
    region = CreateObject("roRegion", bitmap, 0, 0, bitmap.GetWidth(), bitmap.GetHeight()) as roRegion
    region.SetAlphaEnable(true)
    logoRegionWithId = BGE.RendererHelpers.createRegionWithId(region, "logo")

    canvasSize = renderer.getCanvasSize()
    m.gridBitmap = CreateObject("roBitmap", {width: canvasSize.x, height: canvasSize.y, alphaEnable: true})
    gridRenderer = new BGE.Renderer(m.gridBitmap)

    placementOffset = 80
    width = 50
    cols = 16

    for i = 0 to 25
      offset = placementOffset * (i mod cols)
      yOffset = (i \ cols) * placementOffset + 60

      cornerPoints = BGE.Math.createCornerPoints(
        {x: offset, y: width + yOffset},
        {x: width + offset, y: width + yOffset},
        {x: width + offset, y: 2 * width + yOffset},
        {x: 2 * width + offset, y: 2 * width + yOffset}
      )

      gridRenderer.drawPinnedCorners(cornerPoints, logoRegionWithId)
    end for
    m.gridBitmap.Finish()
  end sub

  override sub draw(renderer as BGE.Renderer)
    renderer.drawObject(0, 0, m.gridBitmap)
  end sub

end class
