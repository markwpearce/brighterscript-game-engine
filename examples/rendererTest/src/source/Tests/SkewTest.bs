' Demonstrates BGE.Math.TriangleOps.getThirdRightTrianglePoint() - given two
' points (A, B) and the angle at A, finds the third point of the right
' triangle these form. Used internally for corner-pin/skew math. The angle
' animates continuously so the third point visibly moves as it's
' recomputed every frame.
class SkewTest extends RendererTest

  elapsedSeconds as float = 0

  sub new()
    super("Corner Pin: Skew (getThirdRightTrianglePoint)")
  end sub

  override sub update(dt as float)
    m.elapsedSeconds += dt
  end sub

  override sub draw(renderer as BGE.Renderer)
    aPoint = BGE.Math.VectorOps.create(320, 385)
    bPoint = BGE.Math.VectorOps.create(619, 293)

    renderer.drawSquare(aPoint.x, aPoint.y, 10, BGE.Colors.Red)
    renderer.drawSquare(bPoint.x, bPoint.y, 10, BGE.Colors.Blue)

    aAngle = -1.273 + sin(m.elapsedSeconds) * 0.5
    originPoint = BGE.Math.TriangleOps.getThirdRightTrianglePoint(aPoint, bPoint, aAngle)

    if invalid <> originPoint
      renderer.drawLine(aPoint.x, aPoint.y, originPoint.x, originPoint.y, BGE.Colors.Pink)
      renderer.drawLine(bPoint.x, bPoint.y, originPoint.x, originPoint.y, BGE.Colors.Pink)
      renderer.drawSquare(originPoint.x, originPoint.y, 10, BGE.Colors.Pink)
    end if
  end sub

end class
