' Demonstrates Renderer.drawText()'s horizontal alignment options, and that
' both Chr(10) and a literal newline produce the same multi-line result.
class TextAlignmentTest extends RendererTest

  sub new()
    super("Text: Alignment")
  end sub

  override sub draw(renderer as BGE.Renderer)
    canvasCenter = renderer.getCanvasCenter()

    renderer.drawText("left aligned", 100, 150, BGE.Colors.White, invalid, "left")
    renderer.drawText("center aligned", canvasCenter.x, 250, BGE.Colors.White, invalid, "center")
    renderer.drawText("right aligned", canvasCenter.x * 2 - 100, 350, BGE.Colors.White, invalid, "right")

    renderer.drawText("Hello" + Chr(10) + "World (Chr(10))", canvasCenter.x, 450, BGE.Colors.Cyan, invalid, "center")
    renderer.drawText(`Hello
World (literal newline)`, canvasCenter.x, 550, BGE.Colors.Cyan, invalid, "center")
  end sub

end class
