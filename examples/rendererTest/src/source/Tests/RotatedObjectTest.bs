' Demonstrates Renderer.bmpPool (ScratchBitmapPool) - checking out a scratch
' region, drawing into it, then drawing the result rotated via
' Renderer.drawRotatedObject(). Rotates continuously to make it obvious this
' redraws every frame rather than being a static screenshot.
class RotatedObjectTest extends RendererTest

  logoRegion as roRegion
  elapsedSeconds as float = 0

  sub new()
    super("Corner Pin: Rotated Object via Scratch Region")
  end sub

  override sub setup(renderer as BGE.Renderer)
    bitmap = CreateObject("roBitmap", "pkg:/sprites/roku-logo-purple.png")
    m.logoRegion = CreateObject("roRegion", bitmap, 0, 0, bitmap.GetWidth(), bitmap.GetHeight())
  end sub

  override sub update(dt as float)
    m.elapsedSeconds += dt
  end sub

  override sub draw(renderer as BGE.Renderer)
    scratch = renderer.bmpPool.getRegion(200, 200)
    if invalid = scratch
      return
    end if
    scratch.region.DrawObject(0, 0, m.logoRegion)

    degreesPerSecond = 60
    rotation = BGE.Math.DegreesToRadians((m.elapsedSeconds * degreesPerSecond) mod 360)

    renderer.drawRotatedObject(400, 300, rotation, scratch.region)
    renderer.bmpPool.returnRegion(scratch)
  end sub

end class
